{
  "name": "rn-bundle-swapper",
  "version": "0.1.0",
  "description": "Cross-platform utility for swapping or updating the JavaScript bundle inside existing React Native Android APKs and iOS .app/.ipa files.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "rn-bundle-swapper": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "react-native",
    "bundle",
    "apk",
    "ipa",
    "swap",
    "patch",
    "metro",
    "hermes",
    "android",
    "ios",
    "codesign",
    "apksigner",
    "zipalign",
    "jsbundle",
    "hotswap",
    "ci"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kagrawal61/rn-bundle-swapper.git"
  },
  "homepage": "https://github.com/kagrawal61/rn-bundle-swapper#readme",
  "bugs": {
    "url": "https://github.com/kagrawal61/rn-bundle-swapper/issues"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node src/cli.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "prepare": "node -e \"if(require('fs').existsSync('.git')) { require('child_process').execSync('husky install', {stdio:'inherit'}) }\"",
    "prepublishOnly": "yarn build",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "yarn lint && yarn type-check && yarn format:check && yarn test",
    "bootstrap:sample": "yarn --cwd SampleApp install && (cd SampleApp/ios && pod install --repo-update)"
  },
  "author": "Kushal Agrawal",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "boxen": "^7.0.0",
    "chalk": "^5.6.2",
    "commander": "^11.0.0",
    "execa": "^8.0.0",
    "figlet": "^1.7.0",
    "fs-extra": "^11.3.4",
    "gradient-string": "^2.0.2",
    "log-symbols": "^5.1.0",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.12",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
